# Async SQLAlchemy DSN (Alembic converts +asyncpg → sync psycopg2 for migrations).
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/learnova
JWT_SECRET_KEY=your-super-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
STORAGE_TYPE=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
RESEND_API_KEY=
EMAIL_FROM=noreply@learnova.local
